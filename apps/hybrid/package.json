{
  "name": "@archkit/hybrid-root",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.12.0",
  "description": "TurboRepo monorepo root for the hybrid architecture",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "start:dev": "turbo start:dev --parallel"
  },
  "devDependencies": {
    "turbo": "latest"
  }
}
