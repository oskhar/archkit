{
  "path": "cz-git",
  "scopes": [
    { "name": "constitution", "description": "Project governance and core principles" },
    { "name": "spec", "description": "Feature specifications and requirements" },
    { "name": "plan", "description": "Technical implementation plans" },
    { "name": "tasks", "description": "Task lists and execution tracking" },
    { "name": "research", "description": "Technical research and discovery" },
    { "name": "baseline", "description": "Baseline (monolith) architecture implementation" },
    { "name": "hybrid", "description": "Hybrid (microservices) architecture implementation" },
    { "name": "product", "description": "Product domain logic and services" },
    { "name": "inventory", "description": "Inventory domain logic and services" },
    { "name": "sales", "description": "Sales domain logic and services" },
    { "name": "docker", "description": "Containerization and orchestration" },
    { "name": "kafka", "description": "Event streaming and messaging" },
    { "name": "db", "description": "Database schemas and migrations" },
    { "name": "metrics", "description": "Experiment measurement and data collection" },
    { "name": "contracts", "description": "API and event contracts" },
    { "name": "shared", "description": "Shared utilities and libraries" },
    { "name": "repo", "description": "Repository configuration and tooling" }
  ],
  "types": [
    { "value": "feat", "name": "✨ feat:     Add a new feature", "emoji": "✨" },
    { "value": "fix", "name": "🐛 fix:      Fix a bug", "emoji": "🐛" },
    { "value": "docs", "name": "📚 docs:     Documentation changes", "emoji": "📚" },
    { "value": "style", "name": "💄 style:    Code style changes", "emoji": "💄" },
    { "value": "refactor", "name": "♻️ refactor: Code refactoring", "emoji": "♻️" },
    { "value": "test", "name": "🧪 test:     Add or modify tests", "emoji": "🧪" },
    { "value": "chore", "name": "🔧 chore:    Maintenance tasks or non-code changes", "emoji": "🔧" },
    { "value": "perf", "name": "🚀 perf:     Performance improvements", "emoji": "🚀" },
    { "value": "deps", "name": "📦️ deps:     Update dependencies", "emoji": "📦️" },
    { "value": "security", "name": "🛡 security: Address security vulnerabilities", "emoji": "🛡" },
    { "value": "remove", "name": "🗑️ remove:   Remove obsolete code", "emoji": "🗑️" },
    { "value": "comments", "name": "💬 comments: Add comments to the code", "emoji": "💬" },
    { "value": "error", "name": "🚨 error:    Handle errors or warnings", "emoji": "🚨" },
    { "value": "ux", "name": "🎨 ux:       Improve user experience", "emoji": "🎨" },
    { "value": "config", "name": "⚙️ config:   Changes in project configuration", "emoji": "⚙️" },
    { "value": "files", "name": "📁 files:    Changes in files or directories", "emoji": "📁" },
    { "value": "merge", "name": "🔀 merge:   Merge branch or pull request", "emoji": "🔀" },
    { "value": "revert", "name": "⏪️ revert:   Reverts a previous commit", "emoji": "⏪️" },
    { "value": "init", "name": "⭐ init:     Initialize project", "emoji": "⭐" }
  ],
  "useEmoji": true,
  "emojiAlign": "left"
}
